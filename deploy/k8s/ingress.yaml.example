# Adjust for your ingress controller (nginx, traefik, etc.)
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: predict-ingress
  namespace: predict
  annotations:
    # Adjust for your setup:
    # nginx.ingress.kubernetes.io/ssl-redirect: "true"
    # cert-manager.io/cluster-issuer: letsencrypt-prod
spec:
  rules:
    - host: predict-api.yourdomain.com
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: predict-backend
                port:
                  number: 8000
    - host: predict.yourdomain.com
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: predict-frontend
                port:
                  number: 3000
  # tls:
  #   - hosts:
  #       - predict.yourdomain.com
  #       - predict-api.yourdomain.com
  #     secretName: predict-tls
