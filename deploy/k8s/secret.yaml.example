# Copy to secret.yaml and fill in real values
# Apply with: kubectl apply -f secret.yaml
# DO NOT commit secret.yaml to git
apiVersion: v1
kind: Secret
metadata:
  name: predict-secrets
  namespace: predict
type: Opaque
stringData:
  DATABASE_URL: "postgresql://predict:CHANGE_ME@pg-host:5432/predict"
  OPENAI_API_KEY: "sk-..."
  # Optional:
  # ANTHROPIC_API_KEY: "sk-ant-..."
